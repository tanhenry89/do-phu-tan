<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartScan Pro - Hệ Thống Điểm Danh</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.263.0/lucide.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        #reader { width: 100% !important; border: none !important; border-radius: 1rem; overflow: hidden; }
        #reader__dashboard_section_csr button { 
            background-color: #2563eb !important; color: white !important; border: none !important;
            padding: 8px 16px !important; border-radius: 8px !important; font-weight: bold !important;
        }
        .scan-focus { border: 2px solid #3b82f6; box-shadow: 0 0 20px rgba(59, 130, 246, 0.5); }
    </style>
</head>
<body class="min-h-screen">

    <nav class="bg-white border-b px-6 py-4 flex justify-between items-center sticky top-0 z-50 shadow-sm">
        <div class="flex items-center gap-3">
            <div class="bg-blue-600 p-2 rounded-xl text-white shadow-lg shadow-blue-200">
                <i data-lucide="qr-code"></i>
            </div>
            <div>
                <h1 class="text-lg font-black text-slate-900 uppercase leading-none">SmartScan Pro</h1>
                <p class="text-[10px] font-bold text-slate-400 tracking-widest mt-1">HỆ THỐNG QUẢN TRỊ</p>
            </div>
        </div>
        <div id="live-clock" class="hidden md:block text-sm font-black text-slate-600 bg-slate-100 px-4 py-2 rounded-full">--:--:--</div>
    </nav>

    <main class="max-w-6xl mx-auto p-4 md:p-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <div class="lg:col-span-5 space-y-6">
            <div class="bg-white rounded-[2rem] p-6 shadow-xl border border-slate-100">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-sm font-black text-slate-800 uppercase flex items-center gap-2">
                        <span class="w-2 h-2 bg-blue-600 rounded-full animate-ping"></span>
                        Trạm Quét QR
                    </h3>
                    <div id="cam-status" class="text-[10px] font-black px-3 py-1 rounded-full bg-slate-100 text-slate-400 uppercase">Offline</div>
                </div>

                <div class="relative bg-slate-900 rounded-2xl overflow-hidden aspect-square flex items-center justify-center border-4 border-slate-100 shadow-inner">
                    <div id="reader"></div>
                    <div id="placeholder" class="absolute text-center transition-opacity duration-300">
                        <div class="w-16 h-16 bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-4">
                            <i data-lucide="camera" class="w-8 h-8 text-slate-600"></i>
                        </div>
                        <p class="text-xs font-bold text-slate-500 uppercase tracking-tighter">Sẵn sàng kết nối</p>
                    </div>
                </div>

                <div class="mt-6 space-y-3">
                    <button id="btn-start" onclick="startScanner()" class="w-full py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-black text-sm flex items-center justify-center gap-3 shadow-xl shadow-blue-100 transition-all active:scale-95">
                        <i data-lucide="power"></i> KÍCH HOẠT CAMERA
                    </button>
                    <button id="btn-stop" onclick="stopScanner()" class="hidden w-full py-4 bg-slate-100 hover:bg-red-50 text-slate-500 hover:text-red-600 rounded-2xl font-black text-sm transition-all">
                        TẮT CAMERA
                    </button>
                </div>
                
                <p class="mt-4 text-[10px] text-center text-slate-400 font-medium">
                    Lưu ý: Anh cần chạy trên <b>HTTPS</b> để sử dụng Camera
                </p>
            </div>
        </div>

        <div class="lg:col-span-7 space-y-6">
            <div id="res-card" class="hidden bg-white p-8 rounded-[2rem] shadow-2xl border-l-[12px] border-blue-600 animate-in fade-in slide-in-from-right-4">
                <div class="flex items-center gap-6">
                    <div class="w-20 h-20 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center shadow-inner">
                        <i data-lucide="user-check" class="w-10 h-10"></i>
                    </div>
                    <div class="flex-1">
                        <div class="flex justify-between items-start">
                            <div>
                                <h2 id="res-name" class="text-3xl font-black text-slate-900 uppercase">---</h2>
                                <p id="res-id" class="text-sm font-bold text-blue-500">ID: ---</p>
                            </div>
                            <div id="res-tag" class="px-4 py-1.5 rounded-lg text-xs font-black uppercase bg-green-500 text-white">VÀO</div>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 mt-8">
                    <div class="bg-slate-50 p-4 rounded-2xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase mb-1">Thời gian ghi nhận</p>
                        <p id="res-time" class="text-xl font-black text-slate-700">00:00:00</p>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-2xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase mb-1">Tổng cộng trong ngày</p>
                        <p id="res-total" class="text-xl font-black text-slate-700">0h 0m</p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-[2rem] p-6 shadow-xl border border-slate-100">
                <h3 class="text-sm font-black text-slate-800 uppercase mb-6 flex items-center gap-2">
                    <i data-lucide="history" class="text-blue-600 w-4 h-4"></i> Nhật ký quét hôm nay
                </h3>
                <div id="history-list" class="space-y-3 max-h-[400px] overflow-y-auto pr-2">
                    <div class="text-center py-10 text-slate-300 italic text-sm">Chưa có dữ liệu...</div>
                </div>
            </div>
        </div>
    </main>

    <script>
        let html5QrCode = null;
        let logData = {};

        // Khởi tạo icons và đồng hồ
        window.onload = () => {
            lucide.createIcons();
            setInterval(() => {
                document.getElementById('live-clock').innerText = new Date().toLocaleTimeString('vi-VN');
            }, 1000);
        };

        async function startScanner() {
            const status = document.getElementById('cam-status');
            const placeholder = document.getElementById('placeholder');
            const btnStart = document.getElementById('btn-start');
            const btnStop = document.getElementById('btn-stop');

            try {
                // Kiểm tra xem trình duyệt có hỗ trợ không
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    throw new Error("Trình duyệt không hỗ trợ hoặc đang dùng HTTP.");
                }

                html5QrCode = new Html5Qrcode("reader");
                placeholder.classList.add('opacity-0');
                
                const config = { 
                    fps: 15, 
                    qrbox: { width: 250, height: 250 },
                    aspectRatio: 1.0 
                };

                await html5QrCode.start(
                    { facingMode: "environment" }, 
                    config, 
                    (decodedText) => handleScan(decodedText)
                );

                status.innerText = "Trực tuyến";
                status.className = "text-[10px] font-black px-3 py-1 rounded-full bg-green-500 text-white uppercase";
                btnStart.classList.add('hidden');
                btnStop.classList.remove('hidden');

            } catch (err) {
                console.error("Camera Error:", err);
                alert("KHÔNG THỂ MỞ CAMERA:\n1. Anh hãy đảm bảo web đang chạy HTTPS.\n2. Anh hãy chọn 'Cho phép' khi trình duyệt hỏi quyền camera.");
                status.innerText = "Lỗi";
                status.className = "text-[10px] font-black px-3 py-1 rounded-full bg-red-500 text-white uppercase";
            }
        }

        async function stopScanner() {
            if (html5QrCode) {
                await html5QrCode.stop();
                html5QrCode = null;
                document.getElementById('placeholder').classList.remove('opacity-0');
                document.getElementById('btn-start').classList.remove('hidden');
                document.getElementById('btn-stop').classList.add('hidden');
                document.getElementById('cam-status').innerText = "Offline";
                document.getElementById('cam-status').className = "text-[10px] font-black px-3 py-1 rounded-full bg-slate-100 text-slate-400 uppercase";
            }
        }

        function handleScan(text) {
            // Tạm dừng để xử lý hiệu ứng
            html5QrCode.pause();
            setTimeout(() => html5QrCode.resume(), 2000);

            const parts = text.split('|');
            const id = parts[0].trim();
            const name = parts[1] ? parts[1].trim() : "Nhân viên " + id;
            const now = new Date();

            // Logic tính toán Vào/Ra
            if (!logData[id] || logData[id].status === 'RA') {
                logData[id] = { id, name, time: now, status: 'VÀO', startTime: now, totalMs: logData[id]?.totalMs || 0 };
            } else {
                const sessionMs = now - logData[id].startTime;
                logData[id].time = now;
                logData[id].status = 'RA';
                logData[id].totalMs += sessionMs;
            }

            updateUI(logData[id]);
            beep(); // Tiếng kêu giả lập khi quét thành công
        }

        function updateUI(data) {
            document.getElementById('res-card').classList.remove('hidden');
            document.getElementById('res-name').innerText = data.name;
            document.getElementById('res-id').innerText = "ID: " + data.id;
            document.getElementById('res-time').innerText = data.time.toLocaleTimeString('vi-VN');
            document.getElementById('res-tag').innerText = data.status;
            document.getElementById('res-tag').className = `px-4 py-1.5 rounded-lg text-xs font-black uppercase ${data.status === 'VÀO' ? 'bg-green-500' : 'bg-orange-500'} text-white`;

            const totalMin = Math.floor(data.totalMs / 60000);
            document.getElementById('res-total').innerText = `${Math.floor(totalMin/60)}h ${totalMin%60}m`;

            // Vẽ lại danh sách lịch sử
            const historyList = document.getElementById('history-list');
            const items = Object.values(logData).sort((a,b) => b.time - a.time);
            
            historyList.innerHTML = items.map(item => `
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-transparent hover:border-blue-200 transition-all">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center font-black text-blue-600 shadow-sm text-xs">
                            ${item.status}
                        </div>
                        <div>
                            <p class="text-xs font-black text-slate-800 uppercase">${item.name}</p>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">${item.time.toLocaleTimeString()}</p>
                        </div>
                    </div>
                    <i data-lucide="chevron-right" class="w-4 h-4 text-slate-300"></i>
                </div>
            `).join('');
            lucide.createIcons();
        }

        function beep() {
            const context = new (window.AudioContext || window.webkitAudioContext)();
            const osc = context.createOscillator();
            osc.type = 'sine';
            osc.frequency.setValueAtTime(880, context.currentTime);
            osc.connect(context.destination);
            osc.start();
            osc.stop(context.currentTime + 0.1);
        }
    </script>
</body>
</html>
